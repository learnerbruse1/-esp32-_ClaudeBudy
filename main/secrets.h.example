/**
 * ================================================================
 * secrets.h — 编译期默认配置 (可留空, 运行时用 SoftAP 门户配置)
 * ================================================================
 * 如果你愿意把凭据直接编进固件, 在这里填写; 否则保持占位符,
 * 烧录后用手机连接 "ClaudeBuddy-XXXX" 热点在网页里填写。
 *
 * ⚠️ 不要把真实密钥提交到公开仓库 (本文件已在 .gitignore 中)。
 * ================================================================
 */
#ifndef SECRETS_H
#define SECRETS_H

/* 你的家庭/手机热点 Wi-Fi (仅支持 2.4GHz, ESP32 不支持 5GHz) */
#define DEFAULT_WIFI_SSID    ""
#define DEFAULT_WIFI_PASS    ""

/* Anthropic 官方或你的中转 API 地址 (不要以 / 结尾)
 * 官方: https://api.anthropic.com
 * 中转: 形如 https://your-relay.example.com  (需兼容 /v1/messages 接口) */
#define DEFAULT_API_BASE_URL "https://api.anthropic.com"

/* API 密钥 (Anthropic 的 sk-ant-... 或你中转服务的密钥) */
#define DEFAULT_API_KEY      ""

/* 模型名 (默认用最快最省的 Haiku; 中转可改成你支持的名字) */
#define DEFAULT_MODEL        "claude-haiku-4-5-20251001"

/* 系统提示词: 让回答简短, 适配小屏 */
#define DEFAULT_SYSTEM_PROMPT \
    "你是住在一台学而思小喵掌机里的 AI 伙伴 Claude。" \
    "请用简洁、友好的中文回答, 尽量控制在 150 字以内, 方便在小屏幕上阅读。"

/* 单次回复最大 token (屏幕小, 不必太长) */
#define DEFAULT_MAX_TOKENS   512

#endif /* SECRETS_H */
